# ============================================================
# CLIENT FINDER APP - Configuration
# Copy this file to .env and fill in your credentials
# ============================================================

# --- LinkedIn Credentials ---
# Used for LinkedIn lead scraping (linkedin-api library)
# WARNING: Automated access may risk account restrictions. Use cautiously.
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password

# --- OpenRouter API Keys (comma-separated) ---
# Get from: https://openrouter.ai/keys
OPENROUTER_KEYS=your_openrouter_key_1,your_openrouter_key_2

# --- Gemini API Key (fallback model) ---
# Get from: https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key

# --- SMTP Email Settings ---
# For Gmail: Enable 2FA, then create App Password at
# https://myaccount.google.com/apppasswords
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# --- Your Personal Info (used in email signatures) ---
YOUR_NAME=Your Full Name
YOUR_BUSINESS=Your Business Name
YOUR_TITLE=Full Stack Developer
YOUR_PHONE=+1234567890
YOUR_WEBSITE=https://yourwebsite.com
